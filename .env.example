# Search Providers (at least one required)
# Exa Deep — default, best for official source filtering
EXA_API_KEY=your-exa-api-key-here

# Perplexity Sonar — leanest, search + structured output in one call
PERPLEXITY_API_KEY=your-perplexity-api-key-here
PERPLEXITY_MODEL=sonar-pro

# Tavily + Groq — fallback, requires both keys (search + LLM extraction)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Cron
CRON_SECRET=your-random-secret-here
